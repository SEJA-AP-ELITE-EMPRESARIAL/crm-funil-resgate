# === Backend CRM Funil de Resgate ===
# Copie para .env e ajuste. NUNCA versione o .env real.

# Segredo do Django (gere um novo em produção)
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Banco: "sqlite" (default, zero config) ou "postgres"
CRM_DB_ENGINE=sqlite
# Usado apenas quando CRM_DB_ENGINE=postgres
POSTGRES_DB=crm_funil
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS — origem do frontend Vite em dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Regra de negócio: taxa de comissão recorrente (fração, 0.03 = 3%)
CRM_COMISSAO_RATE=0.03
# Duração padrão do contrato em meses (usada quando o cliente não define)
CRM_MESES_CONTRATO_PADRAO=12
