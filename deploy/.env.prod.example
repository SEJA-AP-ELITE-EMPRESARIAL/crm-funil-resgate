# === Conecta_CRM — env de produção (VPS) ===
# Na VPS: copie para a RAIZ do repo como  .env  e ajuste.
#   cp deploy/.env.prod.example .env
# NUNCA commitar o .env real.

DJANGO_DEBUG=false

# Gere uma chave forte:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=troque-por-uma-chave-forte

# Domínios que servem o app (prod + homolog + loopback do healthcheck)
DJANGO_ALLOWED_HOSTS=conecta-crm.sejaap.com.br,conecta-crm-homolog.sejaap.com.br,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://conecta-crm.sejaap.com.br,https://conecta-crm-homolog.sejaap.com.br

# O nginx do host + Cloudflare já forçam HTTPS → desliga o redirect interno
# (evita loop no healthcheck que bate em http://localhost).
SECURE_SSL_REDIRECT=false

# Front e API são a MESMA origem (nginx proxya /api) → CORS quase irrelevante,
# mas deixamos explícito por segurança.
CORS_ALLOWED_ORIGINS=https://conecta-crm.sejaap.com.br,https://conecta-crm-homolog.sejaap.com.br

# Banco: Supabase (Session pooler — IPv4). Troque SENHA pela senha real do Postgres.
DATABASE_URL=postgresql://postgres.uemwpavjpfqoqgmdzxav:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DB_SSLMODE=require

# Regras de negócio
CRM_COMISSAO_RATE=0.03
CRM_MESES_CONTRATO_PADRAO=12
