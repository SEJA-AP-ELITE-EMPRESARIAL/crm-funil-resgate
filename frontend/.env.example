# === Frontend CRM Funil de Resgate ===
# Em dev, o Vite faz proxy de /api para o backend (veja vite.config.js),
# então normalmente NADA precisa ser configurado aqui.

# Alvo do proxy em dev (default http://localhost:8000)
VITE_PROXY_TARGET=http://localhost:8000

# Em produção (build servido separado do backend), aponte para a API:
# VITE_API_URL=https://api.seu-dominio.com

# Timeout das requisições (ms)
VITE_API_TIMEOUT=60000
